---
import type { CollectionEntry } from 'astro:content';
import { publicImageSrc } from '../lib/images';

import type { EntriesCardAspect } from '../lib/sections';

interface Props {
	lang: 'es' | 'ru';
	entries: CollectionEntry<'pagesEs' | 'pagesRu'>[];
	cardAspect?: EntriesCardAspect;
}

const { lang, entries, cardAspect = 'square' } = Astro.props;
const aspectClass = cardAspect === 'vertical' ? 'aspect-[var(--aspect-vertical)]' : 'aspect-square';
const base = `/${lang}/`;

const cards = entries.map((e) => {
	const d = e.data as Record<string, unknown>;
	const title = String(d.title ?? e.id);
	const subtitle = d.subtitle != null ? String(d.subtitle) : '';
	const img = publicImageSrc(d.image as string | undefined);
	const href = `${base}${e.id}/`;
	const bg = img
		? `linear-gradient(to top, rgba(0,0,0,.94) 0%, rgba(0,0,0,.68) 32%, rgba(0,0,0,.35) 52%, transparent 78%), url('${img.replace(/'/g, '%27')}')`
		: null;
	return { title, subtitle, img, href, bg };
});
---

<div class="my-8 grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
	{
		cards.map(({ title, subtitle, img, href, bg }) => (
			<a
				href={href}
				class:list={[
					'group relative flex flex-col justify-end overflow-hidden rounded border border-[var(--color-border)] p-5 no-underline shadow-sm transition hover:opacity-95',
					aspectClass,
					img
						? 'text-white [box-shadow:inset_0_-5rem_2.5rem_-0.25rem_rgba(0,0,0,0.45)]'
						: 'bg-[var(--color-surface)] text-[var(--color-text)]',
				]}
				style={bg ? { backgroundImage: bg, backgroundSize: 'cover', backgroundPosition: 'center' } : undefined}
			>
				<span
					class:list={[
						'font-heading font-semibold leading-tight tracking-tight',
						img
							? 'text-xl sm:text-2xl [text-shadow:0_1px_3px_rgba(0,0,0,.95),0_2px_16px_rgba(0,0,0,.6)]'
							: 'text-xl sm:text-2xl',
					]}
				>
					{title}
				</span>
				{
					subtitle ? (
						<span
							class:list={[
								'mt-2 text-base leading-snug',
								img
									? 'text-white/95 [text-shadow:0_1px_2px_rgba(0,0,0,.9),0_1px_10px_rgba(0,0,0,.45)]'
									: 'text-[var(--color-text-muted)]',
							]}
						>
							{subtitle}
						</span>
					) : null
				}
			</a>
		))
	}
</div>
