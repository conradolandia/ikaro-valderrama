---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { THEME_STORAGE_KEY } from '../lib/theme';

interface Props {
	lang: 'es' | 'ru';
	title: string;
	description?: string;
	alternateHref?: string;
	/** Full-viewport column: no footer, main fills space under header (home hero). */
	viewportShell?: 'default' | 'home-hero';
}

const { lang, title, description, alternateHref, viewportShell = 'default' } = Astro.props;
const homeHero = viewportShell === 'home-hero';
const documentTitle = title.replace(/\s*\n\s*/g, ' ').replace(/\s+/g, ' ').trim();
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
	<head>
		<meta charset="utf-8" />
		<!-- Before CSS paint: same rules as readThemePreference() in src/lib/theme.ts -->
		<script is:inline define:vars={{ themeKey: THEME_STORAGE_KEY }}>
			(function () {
				try {
					var v = localStorage.getItem(themeKey);
					var dark = false;
					if (v === 'dark') dark = true;
					else if (v === 'light') dark = false;
					else if (window.matchMedia('(prefers-color-scheme: dark)').matches) dark = true;
					document.documentElement.classList.toggle('dark', dark);
				} catch (e) {}
			})();
		</script>
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		{description ? <meta name="description" content={description} /> : null}
		<title>{documentTitle}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Libre+Bodoni:ital,wght@0,400;0,600;0,700;1,400&family=Source+Sans+3:ital,wght@0,400;0,600;1,400&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body
		class:list={[
			'flex flex-col antialiased',
			homeHero ? 'h-dvh max-h-dvh min-h-0 overflow-hidden' : 'min-h-screen',
		]}
	>
		<Header lang={lang} alternateHref={alternateHref} />
		<main
			class:list={[
				'mx-auto min-w-0 w-full flex-1',
				homeHero ? 'flex min-h-0 max-w-none flex-col px-0 py-0' : 'max-w-6xl px-4 py-8',
			]}
		>
			<slot />
		</main>
		{homeHero ? null : <Footer lang={lang} />}
	</body>
</html>
