---
import '../styles/global.css';
/** PhotoSwipe CSS: static import avoids Vite CSS-chunk preload failures when `/_astro/*.css` is mis-served (e.g. Apache rewrite to HTML). */
import 'photoswipe/style.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { THEME_STORAGE_KEY } from '../lib/theme';
import { siteTitles } from '../config/nav';

interface Props {
	lang: 'es' | 'ru';
	title: string;
	description?: string;
	alternateHref?: string;
	/** Full-viewport column: no footer, main fills space under header (home hero). */
	viewportShell?: 'default' | 'home-hero';
}

const { lang, title, description, alternateHref, viewportShell = 'default' } = Astro.props;
const homeHero = viewportShell === 'home-hero';
const documentTitle = title.replace(/\s*\n\s*/g, ' ').replace(/\s+/g, ' ').trim();

const site = Astro.site;
const siteOrigin = site?.origin ?? Astro.url.origin;
const canonicalHref = site ? new URL(Astro.url.pathname, site).href : Astro.url.href;
const ogImageHref = site ? new URL('img/Home.jpg', site).href : `${siteOrigin}/img/Home.jpg`;

const brand = siteTitles[lang];
const ogTitle = `${brand.title} — ${brand.tagline}`;
const defaultDescription =
	lang === 'ru'
		? 'Официальный сайт: музыка, литература, события и контакты.'
		: 'Sitio oficial: música, literatura, actividades y contacto.';
const metaDescription = description ?? defaultDescription;
const ogLocale = lang === 'ru' ? 'ru_RU' : 'es_ES';
const ogLocaleAlt = lang === 'ru' ? 'es_ES' : 'ru_RU';
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
	<head>
		<meta charset="utf-8" />
		<!-- Before CSS paint: same rules as readThemePreference() in src/lib/theme.ts -->
		<script is:inline define:vars={{ themeKey: THEME_STORAGE_KEY }}>
			(function () {
				try {
					var v = localStorage.getItem(themeKey);
					var dark = false;
					if (v === 'dark') dark = true;
					else if (v === 'light') dark = false;
					else if (window.matchMedia('(prefers-color-scheme: dark)').matches) dark = true;
					document.documentElement.classList.toggle('dark', dark);
				} catch (e) {}
			})();
		</script>
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<link rel="canonical" href={canonicalHref} />
		<meta name="description" content={metaDescription} />
		<title>{documentTitle}</title>
		<meta property="og:type" content="website" />
		<meta property="og:site_name" content={brand.title} />
		<meta property="og:title" content={ogTitle} />
		<meta property="og:description" content={metaDescription} />
		<meta property="og:url" content={canonicalHref} />
		<meta property="og:image" content={ogImageHref} />
		<meta property="og:image:type" content="image/jpeg" />
		<meta property="og:image:alt" content={ogTitle} />
		<meta property="og:locale" content={ogLocale} />
		<meta property="og:locale:alternate" content={ogLocaleAlt} />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={ogTitle} />
		<meta name="twitter:description" content={metaDescription} />
		<meta name="twitter:image" content={ogImageHref} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Source+Sans+3:ital,wght@0,400;0,600;1,400&family=Yeseva+One&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body
		class:list={[
			'flex flex-col antialiased',
			homeHero ? 'h-dvh max-h-dvh min-h-0 overflow-hidden' : 'min-h-screen',
		]}
	>
		<Header lang={lang} alternateHref={alternateHref} />
		<main
			class:list={[
				'mx-auto min-w-0 w-full flex-1',
				homeHero ? 'flex min-h-0 max-w-none flex-col px-0 py-0' : 'max-w-6xl px-4 py-8',
			]}
		>
			<slot />
		</main>
		{homeHero ? null : <Footer lang={lang} />}
	</body>
</html>
