---
const canonicalHref = Astro.site ? new URL('es/', Astro.site).href : '/es/';
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>Ikaro Valderrama</title>
		<meta name="robots" content="noindex" />
		<link rel="canonical" href={canonicalHref} />
		<meta http-equiv="refresh" content="0;url=/es/" />
		<style is:inline>
			:root {
				color-scheme: light dark;
			}
			body {
				margin: 0;
				min-height: 100dvh;
				display: flex;
				align-items: center;
				justify-content: center;
				font-family: system-ui, sans-serif;
				background: #1c1a16;
				color: #f4f2e1;
			}
			@media (prefers-color-scheme: light) {
				body {
					background: #f4f2e1;
					color: #2a2620;
				}
				.spinner {
					border-color: #2a2620;
					border-right-color: transparent;
				}
			}
			.spinner {
				width: 2.5rem;
				height: 2.5rem;
				border: 3px solid currentColor;
				border-right-color: transparent;
				border-radius: 50%;
				animation: ik-spin 0.7s linear infinite;
			}
			@keyframes ik-spin {
				to {
					transform: rotate(360deg);
				}
			}
			.sr-only {
				position: absolute;
				width: 1px;
				height: 1px;
				padding: 0;
				margin: -1px;
				overflow: hidden;
				clip: rect(0, 0, 0, 0);
				white-space: nowrap;
				border: 0;
			}
		</style>
		<script is:inline>
			location.replace('/es/');
		</script>
	</head>
	<body>
		<div role="status" aria-live="polite">
			<span class="sr-only">Cargando…</span>
			<div class="spinner" aria-hidden="true"></div>
		</div>
		<noscript>
			<p style="text-align: center; padding: 1rem">
				<a href="/es/">Continuar al sitio</a>
			</p>
		</noscript>
	</body>
</html>
